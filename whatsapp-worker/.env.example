# whatsapp-worker environment (deploy on Railway/VPS — NOT Vercel)

# Shared bearer secret — MUST match WHATSAPP_WORKER_SECRET in the Next.js app (.env.local).
WHATSAPP_WORKER_SECRET=

# Public URL of the Next.js app, so the worker can forward inbound messages.
NEXTJS_URL=https://your-subwise-app.vercel.app

# HTTP port the worker listens on (Railway sets PORT automatically).
PORT=8080

# Human-like send spacing (defaults: 20s–120s). Lower only for testing.
WORKER_MIN_DELAY_MS=20000
WORKER_MAX_DELAY_MS=120000

# Where the persistent WhatsApp session is stored. On Railway, mount a Volume and point this at it
# (e.g. /data) so the QR scan survives restarts/redeploys.
WWEBJS_DATA_PATH=./.wwebjs_auth

# Set automatically by the Dockerfile (system Chromium). Leave blank for local `npm start`
# (Puppeteer uses its own bundled Chromium).
PUPPETEER_EXECUTABLE_PATH=

# WhatsApp Web version pinning (fixes "auth timeout" — the live page is newer than the lib can drive).
# Leave WWEBJS_WEB_VERSION blank to auto-detect the newest snapshot in the wppconnect archive at boot.
# Set it only to force a specific build, e.g. 2.3000.1041976118-alpha (must exist at the remote path).
WWEBJS_WEB_VERSION=
WWEBJS_REMOTE_PATH=https://raw.githubusercontent.com/wppconnect-team/wa-version/main/html/{version}.html
