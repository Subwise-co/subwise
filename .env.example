# ─────────────────────────────────────────────────────────────
# Subscription Graveyard — environment variables
# Copy to .env.local and fill in. Never commit real secrets.
# ─────────────────────────────────────────────────────────────

# Auth.js / NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=                 # openssl rand -hex 32
CRON_SECRET=                     # shared bearer token guarding /api/cron/* routes

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=       # server-only. NEVER expose to the client.

# Google OAuth (Gmail readonly)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── AI parser (LLM) ──
# Provider order: primary is tried first, the other is the automatic fallback on failure/rate-limit.
#   LLM_PROVIDER=groq   (default) → Groq Llama 4 Scout, fall back to Gemini
#   LLM_PROVIDER=gemini           → Gemini, fall back to Groq
LLM_PROVIDER=groq
LLM_BATCH_SIZE=40                # emails per LLM request / per scan-job batch
LLM_BODY_MAX=1000               # chars of email body per email sent to the LLM (TPM control)
LLM_MAX_BACKOFF_MS=8000         # max in-call wait on a 429 before falling back / retrying later
SCAN_MAX_MESSAGES=600           # safety cap on emails collected per scan (full 90-day window)

# Groq (free tier; OpenAI-compatible). Primary by default.
# Multiple keys are rotated round-robin (each key has its own rate/daily limit) so big scans don't
# trip limits — put 2–4 comma-separated keys here. GROQ_API_KEY (single) is still supported.
GROQ_API_KEYS=
GROQ_API_KEY=
# Optional key POOLS (scale): split your keys so scanning, analytics, and Stage-2 clustering don't contend.
# With 10 keys: ~6 in GROQ_SCAN_KEYS (Gmail scan, the volume), ~2 in GROQ_ANALYTICS_KEYS (dashboard/ghost
# spend), ~2 in GROQ_CLUSTER_KEYS (the clustering tie-break — low volume, isolated so a heavy scan can't
# starve it). Each falls back to GROQ_API_KEYS when unset, so the split is OPTIONAL.
GROQ_SCAN_KEYS=
GROQ_ANALYTICS_KEYS=
GROQ_CLUSTER_KEYS=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Ghost-spend FX: live rate is fetched from open.er-api.com (cached) with these static fallbacks.
FX_USD_INR=94

# Gemini (fallback by default). 2.0-flash is suspended — use gemini-2.5-flash or gemini-2.5-flash-lite.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Resend (email fallback)
RESEND_API_KEY=

# Razorpay "Pay What You Saved" tip link
# Guide's GhostSpendBanner reads NEXT_PUBLIC_RAZORPAY_TIP_LINK; we also accept
# NEXT_PUBLIC_RAZORPAY_PAYMENT_LINK as an alias.
NEXT_PUBLIC_RAZORPAY_TIP_LINK=
NEXT_PUBLIC_RAZORPAY_PAYMENT_LINK=

# ── WhatsApp transport ──
# webjs  = whatsapp-web.js worker (MVP default; see whatsapp-worker/)
# meta   = Meta Cloud API (future migration; needs the WHATSAPP_* Meta vars below)
# console = log only (local dev / no creds)
WHATSAPP_PROVIDER=webjs

# whatsapp-web.js worker (when WHATSAPP_PROVIDER=webjs)
WHATSAPP_WORKER_URL=             # e.g. https://subwise-wa-worker.up.railway.app
WHATSAPP_WORKER_SECRET=          # shared secret; MUST match the worker's WHATSAPP_WORKER_SECRET (both directions)

# ── Meta WhatsApp Cloud API ── (only when WHATSAPP_PROVIDER=meta — currently blocked: WABA restricted)
WHATSAPP_PHONE_NUMBER_ID=        # Meta App → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=           # permanent System User token
WHATSAPP_VERIFY_TOKEN=           # strong random string; must match Meta webhook config
WHATSAPP_APP_SECRET=             # Meta App → Settings → Basic → App Secret (for webhook signature verification)

# Optional: monthly digest sponsor line (Phase 2 monetisation)
MONTHLY_DIGEST_SPONSOR_LINE=

# PostHog (product analytics + error tracking). Client sends via the /ingest reverse proxy
# (see next.config.ts); the server-side tracker (lib/analytics.js) reads the HOST below.
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=      # Project API key from PostHog → Settings
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com   # ingestion host (use eu.i.posthog.com for EU)
